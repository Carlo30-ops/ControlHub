{
  "name": "controlhub",
  "private": true,
  "version": "3.2.0",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.controlhub.app",
    "productName": "ControlHub",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "extraResources": [
      {
        "from": "electron/sidecar",
        "to": "sidecar",
        "filter": [
          "**/*",
          "!**/__pycache__",
          "!**/*.pyc",
          "!**/*.pyo",
          "!**/tests/**",
          "!**/docs/**"
        ]
      },
      {
        "from": "python-embed",
        "to": "python-embed",
        "filter": [
          "**/*",
          "!**/__pycache__",
          "!**/*.pyc",
          "!**/*.pyo",
          "!**/Scripts/**",
          "!**/share/**",
          "!**/LICENSE.txt"
        ]
      },
      {
        "from": "install_tesseract.bat",
        "to": "install_tesseract.bat"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ControlHub",
      "include": "installer.nsh",
      "perMachine": true,
      "runAfterFinish": true
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "node scripts/verify-python-embed.js && vite build && electron-builder",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "load-test": "tsx scripts/loadTest.ts",
    "test": "vitest run",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.0.3",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "chokidar": "^5.0.0",
    "electron-store": "^11.0.2",
    "motion": "^12.40.0",
    "p-limit": "^7.3.0",
    "react-beautiful-dnd": "^13.1.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.1.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "fuse.js": "^7.4.2",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.487.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.13.0",
    "recharts": "^2.15.2",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.12",
    "tesseract.js": "^5.1.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5.5.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.9",
    "xlsx": "^0.18.5"
  }
}
